{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dev Tunnels SSH Benchmark Results",
  "description": "Common JSON schema for cross-platform benchmark results.",
  "type": "object",
  "required": ["metadata", "suites"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["platform", "platformVersion", "os", "timestamp", "runCount", "gitCommit"],
      "additionalProperties": false,
      "properties": {
        "platform": {
          "type": "string",
          "description": "Runtime platform identifier (e.g. cs, ts, go)."
        },
        "platformVersion": {
          "type": "string",
          "description": "Runtime version (e.g. .NET 8.0, Node 20.x, go1.22)."
        },
        "os": {
          "type": "string",
          "description": "Operating system description (e.g. darwin-arm64, linux-x64, win-x64)."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the benchmark run."
        },
        "runCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of timed iterations per scenario."
        },
        "gitCommit": {
          "type": "string",
          "description": "Git commit SHA at the time of the run."
        }
      }
    },
    "suites": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "name", "tags", "metrics"],
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "algorithm-encryption",
              "algorithm-hmac",
              "algorithm-kex",
              "algorithm-keygen",
              "algorithm-signature",
              "protocol-serialization",
              "protocol-kex-cycle",
              "session-setup",
              "session-throughput",
              "session-multichannel",
              "e2e-portforward",
              "e2e-reconnect"
            ],
            "description": "Benchmark category for grouping and comparison."
          },
          "name": {
            "type": "string",
            "description": "Human-readable benchmark name."
          },
          "tags": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Key-value pairs for cross-platform matching (e.g. algo, size)."
          },
          "metrics": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "unit", "values", "higherIsBetter"],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Metric name (e.g. throughput, latency, ops)."
                },
                "unit": {
                  "type": "string",
                  "description": "Unit of measurement (e.g. ms, MB/s, ops/s)."
                },
                "values": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  },
                  "description": "One measured value per run."
                },
                "higherIsBetter": {
                  "type": "boolean",
                  "description": "True if higher values indicate better performance."
                }
              }
            }
          },
          "verification": {
            "type": "object",
            "description": "Verification result from --verify flag. Omitted when verification was not run.",
            "required": ["passed"],
            "additionalProperties": false,
            "properties": {
              "passed": {
                "type": "boolean",
                "description": "True if the correctness check passed."
              },
              "error": {
                "type": "string",
                "description": "Error message when verification failed. Omitted on success."
              }
            }
          }
        }
      }
    }
  }
}
